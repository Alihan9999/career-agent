# Google Form Configuration
# Copy this file to .env and fill in your real values
# .env is gitignored — never commit it

GOOGLE_FORM_ID=your_form_id_here

# Field entry IDs (get these from your form's pre-filled link)
FORM_ENTRY_COMPANY=entry.XXXXXXXXX
FORM_ENTRY_JOB_TITLE=entry.XXXXXXXXX
FORM_ENTRY_JOB_URL=entry.XXXXXXXXX
FORM_ENTRY_DATE_APPLIED=entry.XXXXXXXXX
FORM_ENTRY_LOCATION=entry.XXXXXXXXX
FORM_ENTRY_REMOTE_POLICY=entry.XXXXXXXXX
FORM_ENTRY_SALARY_RANGE=entry.XXXXXXXXX
FORM_ENTRY_EMPLOYMENT_TYPE=entry.XXXXXXXXX
FORM_ENTRY_ATS_SCORE=entry.XXXXXXXXX
FORM_ENTRY_STATUS=entry.XXXXXXXXX
FORM_ENTRY_NOTES=entry.XXXXXXXXX
FORM_ENTRY_RESUME_PATH=entry.XXXXXXXXX
