# Dependencies
node_modules/

# Your personal data (real resume content, contact info — never commit)
data/*.md
!data/*.example.md

# Generated application output (contains personal resume/cover letter data)
output/*/
!output/.gitkeep

# Claude Code local settings (machine-specific permissions)
.claude/

# Google Form config (contains your real form URL and entry IDs — never commit)
config/google-form.md
!config/google-form.example.md

# Environment variables (Google Form IDs, any future API keys)
.env
.env.local

# Gap analysis reports (reveals job search targets — keep private)
analysis/

# Project schematics (reveals skill gaps and job search strategy — keep private)
projects/

# PDF artifacts
*.pdf

# OS junk
.DS_Store
Thumbs.db
